      { id: 'gs-046', stage: 'Fase de grupos', group: 'L', dateKey: '2026-06-23', kickoffAt: '2026-06-23T20:00:00Z', venue: 'Foxborough, EE. UU.', homeTeam: 'Inglaterra', awayTeam: 'Ghana', sortOrder: 46 },
      { id: 'gs-047', stage: 'Fase de grupos', group: 'L', dateKey: '2026-06-24', kickoffAt: '2026-06-23T23:00:00Z', venue: 'Foxborough, EE. UU.', homeTeam: 'Panamá', awayTeam: 'Croacia', sortOrder: 47 },
      { id: 'gs-048', stage: 'Fase de grupos', group: 'K', dateKey: '2026-06-24', kickoffAt: '2026-06-24T02:00:00Z', venue: 'Guadalajara, México', homeTeam: 'Colombia', awayTeam: 'RD Congo', sortOrder: 48 },
      { id: 'gs-049', stage: 'Fase de grupos', group: 'B', dateKey: '2026-06-24', kickoffAt: '2026-06-24T19:00:00Z', venue: 'Vancouver, Canadá', homeTeam: 'Suiza', awayTeam: 'Canadá', sortOrder: 49 },
      { id: 'gs-050', stage: 'Fase de grupos', group: 'B', dateKey: '2026-06-24', kickoffAt: '2026-06-24T19:00:00Z', venue: 'Seattle, EE. UU.', homeTeam: 'Bosnia y Herzegovina', awayTeam: 'Qatar', sortOrder: 50 },
      { id: 'gs-051', stage: 'Fase de grupos', group: 'C', dateKey: '2026-06-24', kickoffAt: '2026-06-24T22:00:00Z', venue: 'Atlanta, EE. UU.', homeTeam: 'Marruecos', awayTeam: 'Haití', sortOrder: 51 },
      { id: 'gs-052', stage: 'Fase de grupos', group: 'C', dateKey: '2026-06-24', kickoffAt: '2026-06-24T22:00:00Z', venue: 'Miami, EE. UU.', homeTeam: 'Escocia', awayTeam: 'Brasil', sortOrder: 52 },
      { id: 'gs-053', stage: 'Fase de grupos', group: 'A', dateKey: '2026-06-25', kickoffAt: '2026-06-25T01:00:00Z', venue: 'Guadalajara, México', homeTeam: 'Sudáfrica', awayTeam: 'Corea del Sur', sortOrder: 53 },
      { id: 'gs-054', stage: 'Fase de grupos', group: 'A', dateKey: '2026-06-25', kickoffAt: '2026-06-25T01:00:00Z', venue: 'Ciudad de México, México', homeTeam: 'Chequia', awayTeam: 'México', sortOrder: 54 },
      { id: 'gs-055', stage: 'Fase de grupos', group: 'E', dateKey: '2026-06-25', kickoffAt: '2026-06-25T20:00:00Z', venue: 'Filadelfia, EE. UU.', homeTeam: 'Curazao', awayTeam: 'Costa de Marfil', sortOrder: 55 },
      { id: 'gs-056', stage: 'Fase de grupos', group: 'E', dateKey: '2026-06-25', kickoffAt: '2026-06-25T20:00:00Z', venue: 'Nueva Jersey, EE. UU.', homeTeam: 'Ecuador', awayTeam: 'Alemania', sortOrder: 56 },
      { id: 'gs-057', stage: 'Fase de grupos', group: 'F', dateKey: '2026-06-26', kickoffAt: '2026-06-25T23:00:00Z', venue: 'Kansas City, EE. UU.', homeTeam: 'Túnez', awayTeam: 'Países Bajos', sortOrder: 57 },
      { id: 'gs-058', stage: 'Fase de grupos', group: 'F', dateKey: '2026-06-26', kickoffAt: '2026-06-25T23:00:00Z', venue: 'Arlington, EE. UU.', homeTeam: 'Japón', awayTeam: 'Suecia', sortOrder: 58 },
      { id: 'gs-059', stage: 'Fase de grupos', group: 'D', dateKey: '2026-06-26', kickoffAt: '2026-06-26T02:00:00Z', venue: 'Los Ángeles, EE. UU.', homeTeam: 'Turquía', awayTeam: 'Estados Unidos', sortOrder: 59 },
      { id: 'gs-060', stage: 'Fase de grupos', group: 'D', dateKey: '2026-06-26', kickoffAt: '2026-06-26T02:00:00Z', venue: 'Santa Clara, EE. UU.', homeTeam: 'Paraguay', awayTeam: 'Australia', sortOrder: 60 },
      { id: 'gs-061', stage: 'Fase de grupos', group: 'I', dateKey: '2026-06-26', kickoffAt: '2026-06-26T19:00:00Z', venue: 'Foxborough, EE. UU.', homeTeam: 'Noruega', awayTeam: 'Francia', sortOrder: 61 },
      { id: 'gs-062', stage: 'Fase de grupos', group: 'I', dateKey: '2026-06-26', kickoffAt: '2026-06-26T19:00:00Z', venue: 'Toronto, Canadá', homeTeam: 'Senegal', awayTeam: 'Irak', sortOrder: 62 },
      { id: 'gs-063', stage: 'Fase de grupos', group: 'H', dateKey: '2026-06-27', kickoffAt: '2026-06-27T00:00:00Z', venue: 'Houston, EE. UU.', homeTeam: 'Cabo Verde', awayTeam: 'Arabia Saudita', sortOrder: 63 },
      { id: 'gs-064', stage: 'Fase de grupos', group: 'H', dateKey: '2026-06-27', kickoffAt: '2026-06-27T00:00:00Z', venue: 'Guadalajara, México', homeTeam: 'Uruguay', awayTeam: 'España', sortOrder: 64 },
      { id: 'gs-065', stage: 'Fase de grupos', group: 'G', dateKey: '2026-06-27', kickoffAt: '2026-06-27T03:00:00Z', venue: 'Vancouver, Canadá', homeTeam: 'Nueva Zelanda', awayTeam: 'Bélgica', sortOrder: 65 },
      { id: 'gs-066', stage: 'Fase de grupos', group: 'G', dateKey: '2026-06-27', kickoffAt: '2026-06-27T03:00:00Z', venue: 'Seattle, EE. UU.', homeTeam: 'Egipto', awayTeam: 'Irán', sortOrder: 66 },
      { id: 'gs-067', stage: 'Fase de grupos', group: 'L', dateKey: '2026-06-27', kickoffAt: '2026-06-27T21:00:00Z', venue: 'Nueva Jersey, EE. UU.', homeTeam: 'Panamá', awayTeam: 'Inglaterra', sortOrder: 67 },
      { id: 'gs-068', stage: 'Fase de grupos', group: 'L', dateKey: '2026-06-27', kickoffAt: '2026-06-27T21:00:00Z', venue: 'Filadelfia, EE. UU.', homeTeam: 'Croacia', awayTeam: 'Ghana', sortOrder: 68 },
      { id: 'gs-069', stage: 'Fase de grupos', group: 'K', dateKey: '2026-06-28', kickoffAt: '2026-06-27T23:30:00Z', venue: 'Miami, EE. UU.', homeTeam: 'Colombia', awayTeam: 'Portugal', sortOrder: 69 },
      { id: 'gs-070', stage: 'Fase de grupos', group: 'K', dateKey: '2026-06-28', kickoffAt: '2026-06-27T23:30:00Z', venue: 'Atlanta, EE. UU.', homeTeam: 'RD Congo', awayTeam: 'Uzbekistán', sortOrder: 70 },
      { id: 'gs-071', stage: 'Fase de grupos', group: 'J', dateKey: '2026-06-28', kickoffAt: '2026-06-28T02:00:00Z', venue: 'Kansas City, EE. UU.', homeTeam: 'Argelia', awayTeam: 'Austria', sortOrder: 71 },
      { id: 'gs-072', stage: 'Fase de grupos', group: 'J', dateKey: '2026-06-28', kickoffAt: '2026-06-28T02:00:00Z', venue: 'Arlington, EE. UU.', homeTeam: 'Jordania', awayTeam: 'Argentina', sortOrder: 72 }
    ];

    const els = {
      setupNotice: document.getElementById('setupNotice'),
      googleLoginBtn: document.getElementById('googleLoginBtn'),
      signedInBox: document.getElementById('signedInBox'),
      signedOutHint: document.getElementById('signedOutHint'),
      userAvatar: document.getElementById('userAvatar'),
      authUserName: document.getElementById('authUserName'),
      authUserEmail: document.getElementById('authUserEmail'),
      logoutBtn: document.getElementById('logoutBtn'),
      refreshBtn: document.getElementById('refreshBtn'),
      currentUserLabel: document.getElementById('currentUserLabel'),
      nextMatchLabel: document.getElementById('nextMatchLabel'),
      userPointsLabel: document.getElementById('userPointsLabel'),
      viewTabs: document.getElementById('viewTabs'),
      mobileNav: document.getElementById('mobileNav'),
      tabs: document.getElementById('tabs'),
      summaryGrid: document.getElementById('summaryGrid'),
      podiumWrap: document.getElementById('podiumWrap'),
      matchesTitle: document.getElementById('matchesTitle'),
      matchCountLabel: document.getElementById('matchCountLabel'),
      matchList: document.getElementById('matchList'),
      standingsWrap: document.getElementById('standingsWrap'),
      nextRoundWrap: document.getElementById('nextRoundWrap'),
      argentinaMatchesWrap: document.getElementById('argentinaMatchesWrap'),
      fullFixtureWrap: document.getElementById('fullFixtureWrap'),
      knockoutBracketWrap: document.getElementById('knockoutBracketWrap'),
      adminDisabledNote: document.getElementById('adminDisabledNote'),
      adminPanel: document.getElementById('adminPanel'),
      seedFixtureBtn: document.getElementById('seedFixtureBtn'),
      adminMatchSelect: document.getElementById('adminMatchSelect'),
      adminHomeScore: document.getElementById('adminHomeScore'),
      adminAwayScore: document.getElementById('adminAwayScore'),
      saveResultBtn: document.getElementById('saveResultBtn'),
      clearResultBtn: document.getElementById('clearResultBtn')
    };

    const state = {
      previewMode: true,
      firebaseReady: false,
      auth: null,
      db: null,
      currentUser: null,
      matches: [],
      users: [],
      bets: [],
      selectedDateKey: null,
      currentView: 'resumen',
      previewStore: loadPreviewStore(),
      unsubscribers: []
    };

    init();

    function init() {
      bindEvents();
      if (isFirebaseAvailable() && isFirebaseConfigured()) {
        initFirebaseMode();
      } else {
        initPreviewMode();
      }
      window.setInterval(() => {
        renderHeader();
        renderMatches();
        renderNextRound();
        renderSummary();
      }, 30000);
      runSelfTests();
    }

    function bindEvents() {
      els.googleLoginBtn.addEventListener('click', loginWithGoogle);
      els.logoutBtn.addEventListener('click', logout);
      els.refreshBtn.addEventListener('click', renderAll);
      els.seedFixtureBtn.addEventListener('click', seedFixtureIfAdmin);
      els.adminMatchSelect.addEventListener('change', fillAdminInputsFromSelection);
      els.saveResultBtn.addEventListener('click', saveResultIfAdmin);
      els.clearResultBtn.addEventListener('click', clearResultIfAdmin);

      document.querySelectorAll('[data-view]').forEach((btn) => {
        btn.addEventListener('click', () => setView(btn.dataset.view));
      });
    }

    function setView(view) {
      if (view === 'admin' && !isAdmin()) {
        view = 'resumen';
      }
      state.currentView = view;
      document.querySelectorAll('.view-panel').forEach(panel => {
        panel.classList.toggle('active', panel.id === `view-${view}`);
      });
      document.querySelectorAll('.view-tab').forEach(tab => {
        tab.classList.toggle('active', tab.dataset.view === view);
      });
      els.mobileNav.querySelectorAll('button').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.view === view);
      });
    }

    function initPreviewMode() {
      state.previewMode = true;
      state.firebaseReady = false;
      state.matches = applyPreviewResults(cloneFixture(OFFICIAL_FIXTURE), state.previewStore.matchResults || {});
      state.users = state.previewStore.users;
      state.bets = state.previewStore.bets;
      state.currentUser = state.previewStore.currentUser;
      state.selectedDateKey = getInitialDateKey();

      els.setupNotice.classList.remove('hidden');
      els.setupNotice.innerHTML = '<strong>Modo demo local.</strong> Ya puedes recorrer las secciones Resumen, Apuestas, Clasificación y Fixture. Para activar login real con Google y backend compartido, completa <code>FIREBASE_CONFIG</code> y habilita Google en Firebase Authentication.';
      renderAll();
    }

    function initFirebaseMode() {
      try {
        firebase.initializeApp(FIREBASE_CONFIG);
        state.auth = firebase.auth();
        state.db = firebase.firestore();
        state.previewMode = false;
        state.firebaseReady = true;

        subscribeToCollections();
        state.auth.onAuthStateChanged(async (user) => {
          state.currentUser = user;
          if (user) {
            await upsertCurrentUser(user);
          }
          renderAll();
        });
      } catch (error) {
        console.error(error);
        els.setupNotice.classList.remove('hidden');
        els.setupNotice.innerHTML = '<strong>No se pudo inicializar Firebase.</strong> Revisa <code>FIREBASE_CONFIG</code> o los dominios autorizados.';
        initPreviewMode();
      }
    }

    function subscribeToCollections() {
      clearSubscriptions();
      if (!state.db) return;

      state.unsubscribers.push(
        state.db.collection('matches').orderBy('sortOrder', 'asc').onSnapshot((snapshot) => {
          state.matches = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
          if (!state.selectedDateKey) state.selectedDateKey = getInitialDateKey();
          renderAll();
        })
      );

      state.unsubscribers.push(
        state.db.collection('users').onSnapshot((snapshot) => {
          state.users = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
          renderAll();
        })
      );

      state.unsubscribers.push(
        state.db.collection('bets').onSnapshot((snapshot) => {
          state.bets = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
          renderAll();
        })
      );
    }

    function clearSubscriptions() {
      state.unsubscribers.forEach((unsubscribe) => {
        try { unsubscribe(); } catch (e) {}
      });
      state.unsubscribers = [];
    }

    async function upsertCurrentUser(user) {
      if (!state.db || !user) return;
      await state.db.collection('users').doc(user.uid).set({
        uid: user.uid,
        displayName: user.displayName || user.email?.split('@')[0] || 'Usuario',
        email: user.email || '',
        photoURL: user.photoURL || '',
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }

    async function loginWithGoogle() {
      if (state.previewMode) {
        alert('El login real con Google está preparado en el código. Para activarlo debes completar FIREBASE_CONFIG y habilitar Google en Firebase Authentication.');
        return;
      }
      try {
        const provider = new firebase.auth.GoogleAuthProvider();
        if (window.innerWidth < 720) {
          await state.auth.signInWithRedirect(provider);
        } else {
          await state.auth.signInWithPopup(provider);
        }
      } catch (error) {
        console.error(error);
        alert('No se pudo iniciar sesión con Google.');
      }
    }

    async function logout() {
      if (state.previewMode) {
        alert('Estás en modo demo local. El cierre de sesión real funciona cuando activas Firebase.');
        return;
      }
      if (!state.auth) return;
      await state.auth.signOut();
    }

    async function seedFixtureIfAdmin() {
      if (!isAdmin() || !state.db) return;
      const batch = state.db.batch();
      OFFICIAL_FIXTURE.forEach((match) => {
        batch.set(state.db.collection('matches').doc(match.id), {
          ...match,
          kickoffAtMs: match.kickoffAtMs || Date.parse(match.kickoffAt),
          updatedAt: firebase.firestore.FieldValue.serverTimestamp()
        }, { merge: true });
      });
      await batch.commit();
      alert('Fixture oficial de la fase de grupos 2026 sembrado en Firestore.');
    }

    async function saveResultIfAdmin() {
      if (!isAdmin()) return;
      const matchId = els.adminMatchSelect.value;
      const home = parseScore(els.adminHomeScore.value);
      const away = parseScore(els.adminAwayScore.value);
      if (!matchId || home === null || away === null) {
        alert('Introduce ambos goles.');
        return;
      }

      if (state.previewMode) {
        const match = state.matches.find(item => item.id === matchId);
        if (!match) return;
        match.resultHome = home;
        match.resultAway = away;
        persistPreviewStore();
        renderAll();
        return;
      }

      await state.db.collection('matches').doc(matchId).set({
        resultHome: home,
        resultAway: away,
        status: 'played',
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }

    async function clearResultIfAdmin() {
      if (!isAdmin()) return;
      const matchId = els.adminMatchSelect.value;
      if (!matchId) return;

      if (state.previewMode) {
        const match = state.matches.find(item => item.id === matchId);
        if (!match) return;
        match.resultHome = null;
        match.resultAway = null;
        persistPreviewStore();
        renderAll();
        return;
      }

      await state.db.collection('matches').doc(matchId).set({
        resultHome: null,
        resultAway: null,
        status: 'scheduled',
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }

    async function saveBet(matchId, homeValue, awayValue) {
      const home = parseScore(homeValue);
      const away = parseScore(awayValue);
      if (!state.currentUser) {
        alert('Debes iniciar sesión con Google.');
        return;
      }
      if (home === null || away === null) {
        alert('Introduce ambos goles con valores válidos.');
        return;
      }

      const match = state.matches.find(item => item.id === matchId);
      if (!match) return;
      if (isMatchStarted(match.kickoffAt)) {
        alert('Este partido ya empezó y el pronóstico está bloqueado.');
        return;
      }

      if (state.previewMode) {
        const betId = `${state.currentUser.uid}_${matchId}`;
        const existing = state.previewStore.bets.find(bet => bet.id === betId);
        if (existing) {
          existing.home = home;
          existing.away = away;
        } else {
          state.previewStore.bets.push({ id: betId, uid: state.currentUser.uid, matchId, home, away });
        }
        state.bets = state.previewStore.bets;
        persistPreviewStore();
        renderAll();
        return;
      }

      await state.db.collection('bets').doc(`${state.currentUser.uid}_${matchId}`).set({
        uid: state.currentUser.uid,
        matchId,
        home,
        away,
        updatedAt: firebase.firestore.FieldValue.serverTimestamp()
      }, { merge: true });
    }

    function renderAll() {
      if (!state.selectedDateKey) state.selectedDateKey = getInitialDateKey();
      renderAuthState();
      renderHeader();
      renderSummary();
      renderTabs();
      renderMatches();
      renderStandings();
      renderNextRound();
      renderArgentinaMatches();
      renderFullFixture();
      renderKnockoutBracket();
      renderAdmin();
      if (!isAdmin() && state.currentView === 'admin') {
        state.currentView = 'resumen';
      }
      setView(state.currentView);
    }

    function renderAuthState() {
      const user = state.currentUser;
      const signedIn = !!user;
      els.signedInBox.classList.toggle('hidden', !signedIn);
      els.signedOutHint.classList.toggle('hidden', signedIn);

      if (!signedIn) {
        els.currentUserLabel.textContent = 'Sin sesión';
        els.userPointsLabel.textContent = '0 pts';
        els.authUserName.textContent = 'Sin sesión';
        els.authUserEmail.textContent = 'Entrá con Google';
        els.userAvatar.textContent = 'J';
        return;
      }

      const name = user.displayName || user.email?.split('@')[0] || 'Usuario';
      const email = user.email || (state.previewMode ? 'juanpi@demo.local' : '');
      els.currentUserLabel.textContent = name;
      els.authUserName.textContent = name;
      els.authUserEmail.textContent = state.previewMode ? `${email} · demo local` : email;
      els.userAvatar.textContent = (name || 'U').trim().charAt(0).toUpperCase();
      els.logoutBtn.disabled = state.previewMode;
    }

    function renderHeader() {
      const nextMatch = getUpcomingMatch();
      if (nextMatch) {
        els.nextMatchLabel.innerHTML = `${renderMiniFlag(nextMatch.homeTeam)} ${escapeHtml(nextMatch.homeTeam)} vs ${renderMiniFlag(nextMatch.awayTeam)} ${escapeHtml(nextMatch.awayTeam)} · ${formatDateTime(nextMatch.kickoffAt)}`;
      } else {
        els.nextMatchLabel.textContent = 'Sin próximos partidos';
      }

      if (!state.currentUser) {
        els.userPointsLabel.textContent = '0 pts';
        return;
      }
      els.userPointsLabel.textContent = `${calculateUserPoints(state.currentUser.uid)} pts`;
    }

    function renderSummary() {
      const currentUid = state.currentUser?.uid || null;
      const myBets = currentUid ? state.bets.filter(bet => bet.uid === currentUid) : [];
      const upcomingCount = state.matches.filter(match => !isMatchStarted(match.kickoffAt)).length;
      const resolvedCount = state.matches.filter(match => Number.isInteger(match.resultHome) && Number.isInteger(match.resultAway)).length;
      const openMyBets = myBets.filter(bet => {
        const match = state.matches.find(item => item.id === bet.matchId);
        return match && !isMatchStarted(match.kickoffAt);
      }).length;
      const myPoints = currentUid ? calculateUserPoints(currentUid) : 0;

      els.summaryGrid.innerHTML = `
        <div class="summary-card">
          <div class="label">⭐ Mis puntos</div>
          <div class="value">${myPoints}</div>
          <div class="small">Puntaje acumulado</div>
        </div>
        <div class="summary-card">
          <div class="label">📝 Mis apuestas abiertas</div>
          <div class="value">${openMyBets}</div>
          <div class="small">Todavía editables</div>
        </div>
        <div class="summary-card">
          <div class="label">📅 Partidos por jugar</div>
          <div class="value">${upcomingCount}</div>
          <div class="small">Aún sin empezar</div>
        </div>
        <div class="summary-card">
          <div class="label">🏁 Resultados cargados</div>
          <div class="value">${resolvedCount}</div>
          <div class="small">Listos para puntuar</div>
        </div>
      `;

      const ranking = buildRanking().slice(0, 3);
      if (!ranking.length) {
        els.podiumWrap.innerHTML = '<div class="empty">Todavía no hay suficiente actividad para armar el podio.</div>';
      } else {
        els.podiumWrap.innerHTML = ranking.map((row, index) => `
          <div class="fixture-row">
            <div>${['🥇','🥈','🥉'][index] || '🏅'} ${escapeHtml(row.name)}</div>
            <div><strong>${row.points} pts</strong></div>
          </div>
        `).join('');
      }
    }

    function renderTabs() {
      const dateKeys = [...new Set(state.matches.map(match => match.dateKey))].sort();
      if (!dateKeys.length) {
        els.tabs.innerHTML = '';
        return;
      }
      if (!dateKeys.includes(state.selectedDateKey)) {
        state.selectedDateKey = dateKeys[0];
      }

      els.tabs.innerHTML = dateKeys.map(dateKey => `
        <button class="tab ${dateKey === state.selectedDateKey ? 'active' : ''}" data-date-key="${dateKey}">
          📍 ${formatDateChip(dateKey)}
        </button>
      `).join('');

      els.tabs.querySelectorAll('.tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          state.selectedDateKey = tab.dataset.dateKey;
          renderTabs();
          renderMatches();
        });
      });
    }

    function renderMatches() {
      const matches = state.matches.filter(match => match.dateKey === state.selectedDateKey);
      els.matchesTitle.textContent = `🎯 Apuestas · ${formatDateChip(state.selectedDateKey)}`;
      els.matchCountLabel.textContent = matches.length ? `${matches.length} partidos` : 'Sin partidos';

      if (!matches.length) {
        els.matchList.innerHTML = '<div class="empty">No hay partidos cargados para esta fecha.</div>';
        return;
      }

      els.matchList.innerHTML = matches.map(match => renderMatchCard(match)).join('');

      matches.forEach((match) => {
        const homeInput = document.getElementById(`bet-home-${match.id}`);
        const awayInput = document.getElementById(`bet-away-${match.id}`);
        const saveBtn = document.getElementById(`save-bet-${match.id}`);
        if (!homeInput || !awayInput || !saveBtn) return;
        saveBtn.addEventListener('click', () => saveBet(match.id, homeInput.value, awayInput.value));
      });
    }

    function renderMatchCard(match) {
      const bet = getCurrentUserBet(match.id);
      const hasResult = Number.isInteger(match.resultHome) && Number.isInteger(match.resultAway);
      const locked = isMatchStarted(match.kickoffAt);
      const points = hasResult && bet ? calculatePointsForBet(bet, match) : null;
      const statusBadge = hasResult
        ? `<span class="tag good">🏁 Resultado real: ${match.resultHome}-${match.resultAway}</span>`
        : `<span class="tag ${locked ? 'warn' : 'accent'}">${locked ? '⏳ Partido iniciado' : '📝 Pronóstico abierto'}</span>`;
      const lockBadge = locked
        ? `<span class="tag warn">🔒 Cerró ${formatDateTime(match.kickoffAt)}</span>`
        : `<span class="tag accent">🕒 Apuesta hasta ${formatDateTime(match.kickoffAt)}</span>`;
      const pointsBadge = hasResult && !bet
        ? '<span class="tag bad">➖ Sin apuesta: 0 puntos</span>'
        : points === null
          ? '<span class="tag">⭐ Pendiente</span>'
          : `<span class="tag ${points >= 2 ? 'good' : 'warn'}">⭐ ${points} ${points === 1 ? 'punto' : 'puntos'}</span>`;

      return `
        <article class="match-card">
          <div class="match-header">
            <span>Grupo ${escapeHtml(match.group)} · ${formatDateTime(match.kickoffAt)}</span>
            <span>${escapeHtml(match.venue)}</span>
          </div>

          <div class="match-body">
            <div class="team">
              ${renderFlag(match.homeTeam)}
              <div>
                <div class="team-name">${escapeHtml(match.homeTeam)}</div>
                <div class="team-meta">Local</div>
              </div>
            </div>

            <div class="score-box">
              <input id="bet-home-${match.id}" type="number" min="0" value="${bet ? bet.home : ''}" ${!state.currentUser || locked ? 'disabled' : ''} />
              <span class="score-sep">-</span>
              <input id="bet-away-${match.id}" type="number" min="0" value="${bet ? bet.away : ''}" ${!state.currentUser || locked ? 'disabled' : ''} />
            </div>

            <div class="team right">
              <div>
                <div class="team-name">${escapeHtml(match.awayTeam)}</div>
                <div class="team-meta">Visitante</div>
              </div>
              ${renderFlag(match.awayTeam)}
            </div>
          </div>

          <div class="deadline-row">
            ${lockBadge}
            ${statusBadge}
            ${pointsBadge}
          </div>

          <div class="match-footer">
            <div class="small">${bet ? `Tu apuesta: ${bet.home}-${bet.away}` : 'Todavía no apostaste este partido.'}</div>
            <button id="save-bet-${match.id}" class="${locked || !state.currentUser ? 'btn-secondary' : 'btn-primary'}" ${locked || !state.currentUser ? 'disabled' : ''}>Guardar pronóstico</button>
          </div>
        </article>
      `;
    }

    function renderStandings() {
      const rows = buildRanking();
      if (!rows.length) {
        els.standingsWrap.innerHTML = '<div class="empty">Todavía no hay usuarios. Inicien sesión y arranca la competencia familiar.</div>';
        return;
      }

      const currentUid = state.currentUser?.uid || null;

      els.standingsWrap.innerHTML = `
        <table class="standings-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Usuario</th>
              <th>Puntos</th>
              <th>Exactos</th>
              <th>Aciertos</th>
              <th>Pronósticos</th>
            </tr>
          </thead>
          <tbody>
            ${rows.map((row, index) => `
              <tr class="${currentUid && currentUid === row.id ? 'highlight' : ''}">
                <td>${index + 1}</td>
                <td>${escapeHtml(row.name)}</td>
                <td><strong>${row.points}</strong></td>
                <td>${row.exact}</td>
                <td>${row.outcomes}</td>
                <td>${row.bets}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;
    }

    function renderNextRound() {
      const nextDateKey = getNextUpcomingDateKey();
      if (!nextDateKey) {
        els.nextRoundWrap.innerHTML = '<div class="empty">No hay próximas fechas pendientes.</div>';
        return;
      }

      const matches = state.matches.filter(match => match.dateKey === nextDateKey);
      els.nextRoundWrap.innerHTML = `
        <div class="tag accent">📍 ${formatDateChip(nextDateKey)}</div>
        ${matches.map(match => `
          <div class="fixture-mini">
            <div class="inline-flag-pair">${renderMiniFlag(match.homeTeam)} ${escapeHtml(match.homeTeam)} vs ${renderMiniFlag(match.awayTeam)} ${escapeHtml(match.awayTeam)}</div>
            <div class="small">${formatTime(match.kickoffAt)}</div>
          </div>
        `).join('')}
      `;
    }

    function renderArgentinaMatches() {
      const argentinaMatches = [...state.matches]
        .filter(match => match.homeTeam === 'Argentina' || match.awayTeam === 'Argentina')
        .sort((a, b) => (a.sortOrder || 0) - (b.sortOrder || 0));

      if (!argentinaMatches.length) {
        els.argentinaMatchesWrap.innerHTML = '<div class="empty">Todavía no hay partidos de Argentina cargados.</div>';
        return;
      }

      els.argentinaMatchesWrap.innerHTML = argentinaMatches.map(match => {
        const hasResult = Number.isInteger(match.resultHome) && Number.isInteger(match.resultAway);
        const resultLabel = hasResult
          ? `<span class="tag good">Resultado: ${match.resultHome}-${match.resultAway}</span>`
          : `<span class="tag accent">${isMatchStarted(match.kickoffAt) ? 'En juego o cerrado' : 'Próximo partido'}</span>`;
        return `
          <div class="fixture-row">
            <div>
              <div class="inline-flag-pair">${renderMiniFlag(match.homeTeam)} ${escapeHtml(match.homeTeam)} vs ${renderMiniFlag(match.awayTeam)} ${escapeHtml(match.awayTeam)}</div>
              <div class="small">Grupo ${escapeHtml(match.group)} · ${formatDateTime(match.kickoffAt)} · ${escapeHtml(match.venue)}</div>
            </div>
            <div>${resultLabel}</div>
          </div>
        `;
      }).join('');
    }

    function renderFullFixture() {
      const byDate = [...new Set(state.matches.map(match => match.dateKey))].sort();
      if (!byDate.length) {
        els.fullFixtureWrap.innerHTML = '<div class="empty">No hay fixture cargado.</div>';
        return;
      }

      els.fullFixtureWrap.innerHTML = byDate.map(dateKey => {
        const matches = state.matches.filter(match => match.dateKey === dateKey);
        return `
          <div class="fixture-day">${formatDateChip(dateKey)}</div>
          ${matches.map(match => `
            <div class="fixture-row">
              <div class="inline-flag-pair">${renderMiniFlag(match.homeTeam)} ${escapeHtml(match.homeTeam)} vs ${renderMiniFlag(match.awayTeam)} ${escapeHtml(match.awayTeam)}</div>
              <div class="small">${formatTime(match.kickoffAt)}</div>
            </div>
          `).join('')}
        `;
      }).join('');
    }

    function renderKnockoutBracket() {
      els.knockoutBracketWrap.innerHTML = `
        <div class="bracket-wrap">
          <div class="bracket-grid">
            ${KNOCKOUT_BRACKET.map((round) => `
              <div class="bracket-column">
                <div class="bracket-round-title">
                  <span>${round.round}</span>
                  <small>${round.window}</small>
                </div>
                ${round.matches.map((match) => `
                  <div class="bracket-match ${match.final ? 'final' : ''}">
                    <div class="bracket-match-header">
                      <span>${match.id}</span>
                      <span>${round.round}</span>
                    </div>
                    <div class="bracket-team">${escapeHtml(match.home)}</div>
                    <div class="bracket-team">${escapeHtml(match.away)}</div>
                  </div>
                `).join('')}
              </div>
            `).join('')}
          </div>
        </div>
        <div class="bracket-note">
          El cuadro muestra el camino oficial desde la fase de grupos hasta la final. Los equipos reales se completarán cuando se definan los 1º, 2º y los ocho mejores terceros de grupo.
        </div>
      `;
    }

    function renderAdmin() {
      const admin = isAdmin();
      const desktopAdminTab = document.getElementById('desktopAdminTab');
      const mobileAdminTab = document.getElementById('mobileAdminTab');
      const adminView = document.getElementById('view-admin');

      if (desktopAdminTab) desktopAdminTab.classList.toggle('hidden', !admin);
      if (mobileAdminTab) mobileAdminTab.classList.toggle('hidden', !admin);
      if (adminView) adminView.classList.toggle('hidden', !admin);

      els.adminDisabledNote.classList.toggle('hidden', admin);
      els.adminPanel.classList.toggle('hidden', !admin);

      const options = state.matches.map((match) => {
        const resultLabel = Number.isInteger(match.resultHome) && Number.isInteger(match.resultAway)
          ? ` · ${match.resultHome}-${match.resultAway}`
          : '';
        return `<option value="${match.id}">${formatDateChip(match.dateKey)} · Grupo ${match.group} · ${escapeHtml(match.homeTeam)} vs ${escapeHtml(match.awayTeam)}${resultLabel}</option>`;
      });
      els.adminMatchSelect.innerHTML = options.length ? options.join('') : '<option value="">No hay partidos</option>';
      fillAdminInputsFromSelection();
    }

    function fillAdminInputsFromSelection() {
      const match = state.matches.find(item => item.id === els.adminMatchSelect.value);
      els.adminHomeScore.value = match && Number.isInteger(match.resultHome) ? match.resultHome : '';
      els.adminAwayScore.value = match && Number.isInteger(match.resultAway) ? match.resultAway : '';
    }

    function buildRanking() {
      return state.users
        .map((user) => {
          const uid = user.uid || user.id;
          return {
            id: uid,
            name: user.displayName || user.email || 'Usuario',
            points: calculateUserPoints(uid),
            exact: countExactHits(uid),
            outcomes: countOutcomeHits(uid),
            bets: countUserBets(uid)
          };
        })
        .sort((a, b) => b.points - a.points || b.exact - a.exact || b.outcomes - a.outcomes || a.name.localeCompare(b.name, 'es'));
    }

    function getCurrentUserBet(matchId) {
      if (!state.currentUser) return null;
      return state.bets.find(bet => bet.uid === state.currentUser.uid && bet.matchId === matchId) || null;
    }

    function calculateUserPoints(uid) {
      return state.bets
        .filter(bet => bet.uid === uid)
        .reduce((total, bet) => {
          const match = state.matches.find(item => item.id === bet.matchId);
          if (!match || !Number.isInteger(match.resultHome) || !Number.isInteger(match.resultAway)) return total;
          return total + calculatePointsForBet(bet, match);
        }, 0);
    }

    function countExactHits(uid) {
      return state.bets
        .filter(bet => bet.uid === uid)
        .reduce((count, bet) => {
          const match = state.matches.find(item => item.id === bet.matchId);
          if (!match || !Number.isInteger(match.resultHome) || !Number.isInteger(match.resultAway)) return count;
          return bet.home === match.resultHome && bet.away === match.resultAway ? count + 1 : count;
        }, 0);
    }

    function countOutcomeHits(uid) {
      return state.bets
        .filter(bet => bet.uid === uid)
        .reduce((count, bet) => {
          const match = state.matches.find(item => item.id === bet.matchId);
          if (!match || !Number.isInteger(match.resultHome) || !Number.isInteger(match.resultAway)) return count;
          return getOutcome(bet.home, bet.away) === getOutcome(match.resultHome, match.resultAway) ? count + 1 : count;
        }, 0);
    }

    function countUserBets(uid) {
      return state.bets.filter(bet => bet.uid === uid).length;
    }

    function calculatePointsForBet(bet, match) {
      if (bet.home === match.resultHome && bet.away === match.resultAway) return 4;
      if (getOutcome(bet.home, bet.away) === getOutcome(match.resultHome, match.resultAway)) return 2;
      return 1;
    }

    function getOutcome(home, away) {
      if (home > away) return 'home';
      if (home < away) return 'away';
      return 'draw';
    }

    function getUpcomingMatch() {
      const now = Date.now();
      return [...state.matches]
        .filter(match => getDateMs(match.kickoffAt) > now)
        .sort((a, b) => getDateMs(a.kickoffAt) - getDateMs(b.kickoffAt))[0] || null;
    }

    function getNextUpcomingDateKey() {
      const next = getUpcomingMatch();
      return next?.dateKey || null;
    }

    function getInitialDateKey() {
      return [...new Set(state.matches.map(match => match.dateKey))].sort()[0] || '2026-06-11';
    }

    function isMatchStarted(kickoffAt) {
      const time = getDateMs(kickoffAt);
      return time !== null ? time <= Date.now() : false;
    }

    function isAdmin() {
      const email = state.currentUser?.email?.toLowerCase() || '';
      if (state.previewMode) return true;
      return ADMIN_EMAILS.map(item => item.toLowerCase()).includes(email);
    }

    function isFirebaseAvailable() {
      return typeof window.firebase !== 'undefined';
    }

    function isFirebaseConfigured() {
      return FIREBASE_CONFIG.apiKey && !String(FIREBASE_CONFIG.apiKey).includes('PON_AQUI');
    }

    function parseScore(value) {
      if (value === '' || value === null || value === undefined) return null;
      const num = Number(value);
      if (!Number.isInteger(num) || num < 0) return null;
      return num;
    }

    function safeDate(value) {
      if (typeof value !== 'string' && typeof value !== 'number' && !(value instanceof Date)) return null;
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? null : date;
    }

    function getDateMs(value) {
      const date = safeDate(value);
      return date ? date.getTime() : null;
    }

    function formatDateTime(value) {
      const date = safeDate(value);
      if (!date) return 'Fecha inválida';
      return new Intl.DateTimeFormat('es-ES', {
        day: '2-digit',
        month: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      }).format(date);
    }

    function formatTime(value) {
      const date = safeDate(value);
      if (!date) return '--:--';
      return new Intl.DateTimeFormat('es-ES', {
        hour: '2-digit',
        minute: '2-digit'
      }).format(date);
    }

    function formatDateChip(dateKey) {
      const date = safeDate(`${dateKey}T12:00:00`);
      if (!date) return dateKey;
      return new Intl.DateTimeFormat('es-ES', {
        weekday: 'short',
        day: '2-digit',
        month: 'short'
      }).format(date);
    }

    function escapeHtml(str) {
      return String(str ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function cloneFixture(fixture) {
      return fixture.map(match => ({ ...match, resultHome: match.resultHome ?? null, resultAway: match.resultAway ?? null }));
    }

    function loadPreviewStore() {
      const fallback = {
        currentUser: { uid: 'preview-jp', displayName: 'Juan Pablo', email: 'juanpi@demo.local' },
        users: [
          { uid: 'preview-jp', displayName: 'Juan Pablo', email: 'juanpi@demo.local' },
          { uid: 'preview-flor', displayName: 'Flor', email: 'flor@demo.local' },
          { uid: 'preview-dante', displayName: 'Dante', email: 'dante@demo.local' }
        ],
        bets: [],
        matchResults: {}
      };

      try {
        const raw = localStorage.getItem(PREVIEW_STORAGE_KEY);
        if (!raw) return fallback;
        const parsed = JSON.parse(raw);
        return {
          currentUser: parsed.currentUser || fallback.currentUser,
          users: Array.isArray(parsed.users) && parsed.users.length ? parsed.users : fallback.users,
          bets: Array.isArray(parsed.bets) ? parsed.bets : [],
          matchResults: parsed.matchResults && typeof parsed.matchResults === 'object' ? parsed.matchResults : {}
        };
      } catch (error) {
        console.warn('No se pudo cargar el modo demo.', error);
        return fallback;
      }
    }

    function persistPreviewStore() {
      state.previewStore.matchResults = Object.fromEntries(
        state.matches
          .filter(match => Number.isInteger(match.resultHome) && Number.isInteger(match.resultAway))
          .map(match => [match.id, { resultHome: match.resultHome, resultAway: match.resultAway }])
      );
      localStorage.setItem(PREVIEW_STORAGE_KEY, JSON.stringify(state.previewStore));
    }

    function applyPreviewResults(matches, matchResults) {
      return matches.map(match => {
        const saved = matchResults?.[match.id];
        return {
          ...match,
          resultHome: Number.isInteger(saved?.resultHome) ? saved.resultHome : null,
          resultAway: Number.isInteger(saved?.resultAway) ? saved.resultAway : null
        };
      });
    }

    function getFlagCode(teamName) {
      return FLAG_CODE_BY_TEAM[teamName] || null;
    }

    function getCustomFlagSvg(teamName) {
      if (teamName === 'Inglaterra') {
        return `data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 45'><rect width='60' height='45' fill='white'/><rect x='24' width='12' height='45' fill='%23c8102e'/><rect y='16.5' width='60' height='12' fill='%23c8102e'/></svg>`)}`;
      }
      if (teamName === 'Escocia') {
        return `data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 45'><rect width='60' height='45' fill='%230052b4'/><path d='M0 0 L8 0 L60 37 L60 45 L52 45 L0 8 Z' fill='white'/><path d='M52 0 L60 0 L60 8 L8 45 L0 45 L0 37 Z' fill='white'/></svg>`)}`;
      }
      return null;
    }

    function getFlagSrc(teamName) {
      const custom = getCustomFlagSvg(teamName);
      if (custom) return custom;
      const code = getFlagCode(teamName);
      return code ? `https://flagcdn.com/w80/${code}.png` : null;
    }

    function renderFlag(teamName) {
      const src = getFlagSrc(teamName);
      const fallback = escapeHtml(teamName.slice(0, 1).toUpperCase());
      return `<div class="flag">${src ? `<img class="flag-img" src="${src}" alt="Bandera de ${escapeHtml(teamName)}" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />` : ''}<span class="flag-fallback" style="display:${src ? 'none' : 'grid'}">${fallback}</span></div>`;
    }

    function renderMiniFlag(teamName) {
      const src = getFlagSrc(teamName);
      const fallback = escapeHtml(teamName.slice(0, 1).toUpperCase());
      return `<span class="mini-flag">${src ? `<img src="${src}" alt="Bandera de ${escapeHtml(teamName)}" loading="lazy" referrerpolicy="no-referrer" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />` : ''}<span class="flag-fallback" style="display:${src ? 'none' : 'grid'}">${fallback}</span></span>`;
    }

    function runSelfTests() {
      const tests = [
        { name: 'safeDate rechaza fechas inválidas', run: () => safeDate('fecha-rota') === null },
        { name: 'parseScore rechaza negativos', run: () => parseScore(-1) === null },
        { name: 'puntaje exacto suma 4', run: () => calculatePointsForBet({ home: 2, away: 1 }, { resultHome: 2, resultAway: 1 }) === 4 },
        { name: 'puntaje por signo suma 2', run: () => calculatePointsForBet({ home: 1, away: 0 }, { resultHome: 3, resultAway: 0 }) === 2 },
        { name: 'puntaje por apostar y fallar suma 1', run: () => calculatePointsForBet({ home: 0, away: 1 }, { resultHome: 3, resultAway: 0 }) === 1 },
        { name: 'fixture tiene códigos de bandera', run: () => OFFICIAL_FIXTURE.every(match => FLAG_CODE_BY_TEAM[match.homeTeam] && FLAG_CODE_BY_TEAM[match.awayTeam]) },
        { name: 'fixture tiene fechas válidas', run: () => OFFICIAL_FIXTURE.every(match => !!safeDate(match.kickoffAt)) },
        { name: 'antes de iniciar permite apostar', run: () => isMatchStarted(new Date(Date.now() + 60000).toISOString()) === false },
        { name: 'al iniciar o después bloquea apuesta', run: () => isMatchStarted(new Date(Date.now() - 60000).toISOString()) === true },
        { name: 'cambio de vista funciona', run: () => ['resumen','apuestas','clasificacion','fixture','admin'].includes(state.currentView) },
        { name: 'admin solo permitido a correo especial', run: () => ADMIN_EMAILS.length === 1 && ADMIN_EMAILS[0] === 'gerbijuan@gmail.com' },
        { name: 'cuadro final tiene seis rondas', run: () => KNOCKOUT_BRACKET.length === 6 }
      ];

      const failed = tests.filter(test => {
        try {
          return !test.run();
        } catch (error) {
          console.error(`Test falló: ${test.name}`, error);
          return true;
        }
      });

      if (failed.length) {
        console.error('Fallaron tests internos:', failed.map(t => t.name));
      } else {
        console.info('Tests internos OK:', tests.map(t => t.name));
      }
    }
  </script>
</body>
</html>
