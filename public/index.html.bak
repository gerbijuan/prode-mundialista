      </section>

      <section id="view-resumen" class="view-panel active">
        <div class="summary-grid" id="summaryGrid"></div>
        <div class="cards-grid">
          <div class="card">
            <div class="section-title">
              <h3>📍 Próxima fecha</h3>
              <span class="small">Lo que viene</span>
            </div>
            <div id="nextRoundWrap"></div>
          </div>
          <div class="card">
            <div class="section-title">
              <h3>🏆 Podio familiar</h3>
              <span class="small">Top 3</span>
            </div>
            <div id="podiumWrap"></div>
          </div>
        </div>
      </section>

      <section id="view-apuestas" class="view-panel">
        <section class="tabs" id="tabs"></section>
        <div class="card">
          <div class="section-title">
            <h3 id="matchesTitle">🎯 Apuestas</h3>
            <span class="small" id="matchCountLabel"></span>
          </div>
          <div id="matchList" class="fixture-list"></div>
        </div>
      </section>

      <section id="view-clasificacion" class="view-panel">
        <div class="card">
          <div class="section-title">
            <h3>🥇 Clasificación general</h3>
            <span class="small">Puntaje en tiempo real</span>
          </div>
          <div id="standingsWrap"></div>
        </div>
      </section>

      <section id="view-fixture" class="view-panel">
        <div class="fixture-stack">
          <div class="card argentina-highlight">
            <div class="section-title">
              <h3>🇦🇷 Partidos de Argentina</h3>
              <span class="small">Seguimiento especial de la Scaloneta</span>
            </div>
            <div id="argentinaMatchesWrap"></div>
          </div>
          <div class="card">
            <div class="section-title">
              <h3>🗓️ Fixture completo</h3>
              <span class="small">Fase de grupos</span>
            </div>
            <div id="fullFixtureWrap"></div>
          </div>
          <div class="card">
            <div class="section-title">
              <h3>🏆 Cuadro final</h3>
              <span class="small">Cruces hasta la final</span>
            </div>
            <div id="knockoutBracketWrap"></div>
          </div>
        </div>
      </section>

      <section id="view-admin" class="view-panel">
        <div class="card">
          <div class="section-title">
            <h3>⚙️ Administración</h3>
            <span class="small">Resultados y siembra</span>
          </div>
          <div id="adminDisabledNote" class="panel-note">
            Esta zona sólo aparece si la cuenta logueada está incluida en <code>ADMIN_EMAILS</code>.
          </div>
          <div id="adminPanel" class="hidden">
            <div class="small">Desde acá podés sembrar el fixture oficial 2026 en Firestore y cargar resultados manualmente. También se puede automatizar con una función programada que consulte una API de resultados cada hora.</div>
            <div class="admin-box">
              <button id="seedFixtureBtn" class="btn-primary">Sembrar fixture 2026 en Firebase</button>
              <select id="adminMatchSelect"></select>
              <div class="row">
                <input id="adminHomeScore" type="number" min="0" placeholder="Goles local" />
                <input id="adminAwayScore" type="number" min="0" placeholder="Goles visitante" />
              </div>
              <div class="result-actions">
                <button id="saveResultBtn" class="btn-primary">Guardar resultado</button>
                <button id="clearResultBtn" class="btn-secondary">Quitar resultado</button>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

